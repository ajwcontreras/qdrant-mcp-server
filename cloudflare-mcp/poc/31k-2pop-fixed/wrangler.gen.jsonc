{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cfcode-poc-31k-2pop",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true, "head_sampling_rate": 1 },
  "r2_buckets": [{ "binding": "ARTIFACTS", "bucket_name": "cfcode-poc-31k-2pop" }],
  "d1_databases": [{ "binding": "DB", "database_name": "cfcode-poc-31k-2pop", "database_id": "d7334315-6814-41ac-a54a-d0957160538c" }],
  "vectorize": [{ "binding": "VECTORIZE", "index_name": "cfcode-poc-31k-2pop" }],
  "durable_objects": { "bindings": [{ "name": "CODE_DO", "class_name": "CodeShardDO" }, { "name": "HYDE_DO", "class_name": "HydeShardDO" }, { "name": "ORCH_DO", "class_name": "OrchestratorDO" }] },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["CodeShardDO", "HydeShardDO", "OrchestratorDO"] }],
  "vars": { "CODE_SHARD_COUNT": "4", "HYDE_SHARD_COUNT": "64", "CODE_BATCH_SIZE": "500", "HYDE_BATCH_SIZE": "500", "NUM_SAS": "2", "HYDE_QUESTIONS": "12", "HYDE_MODEL": "deepseek-v4-flash", "HYDE_VERSION": "v1" }
}
