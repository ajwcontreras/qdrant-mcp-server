{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "__WORKER_NAME__",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-30",
  "compatibility_flags": ["nodejs_compat"],
  "r2_buckets": [{ "binding": "ARTIFACTS", "bucket_name": "__R2_BUCKET__" }],
  "d1_databases": [{ "binding": "DB", "database_name": "__D1_NAME__", "database_id": "__D1_ID__" }],
  "vectorize": [{ "binding": "VECTORIZE", "index_name": "__VECTORIZE_INDEX__" }],
  "durable_objects": {
    "bindings": [
      { "name": "CODE_SHARD_DO", "class_name": "CodeShardDO" },
      { "name": "HYDE_SHARD_DO", "class_name": "HydeShardDO" },
      { "name": "JOB_ORCHESTRATOR_DO", "class_name": "JobOrchestratorDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["CodeShardDO", "HydeShardDO", "JobOrchestratorDO"] }
  ],
  "vars": {
    "CODE_SHARD_COUNT": "4",
    "HYDE_SHARD_COUNT": "16",
    "CODE_BATCH_SIZE": "100",
    "HYDE_BATCH_SIZE": "100",
    "NUM_SAS": "2",
    "HYDE_QUESTIONS": "12",
    "HYDE_MODEL": "deepseek-v4-flash",
    "HYDE_VERSION": "v1"
  }
}
